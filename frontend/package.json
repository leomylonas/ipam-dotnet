{
	"name": "ipam-ui",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.22.0",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --noEmit",
		"typecheck:fast": "tsgo --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install --with-deps",
		"prepare": "cd .. && git config core.hooksPath frontend/.husky || true"
	},
	"dependencies": {
		"@carbon/icons-react": "^11.80.0",
		"@carbon/layout": "^11.53.0",
		"@carbon/react": "^1.107.1",
		"@hookform/resolvers": "^5.2.2",
		"@leomylonas/json-fetch-client": "^0.0.2",
		"@tanstack/react-query": "^5.100.10",
		"@tanstack/react-router": "^1.170.4",
		"react": "^18",
		"react-dom": "^18",
		"react-granular-store": "^0.2.0",
		"react-hook-form": "^7.76.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.60.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"@types/node": "^20.0.0",
		"@types/react": "^18",
		"@types/react-dom": "^18",
		"@typescript/native-preview": "7.0.0-dev.20260518.1",
		"@vitejs/plugin-react": "^6.0.2",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^3.10.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"jiti": "^2.7.0",
		"jsdom": "^29.1.1",
		"lint-staged": "^15.5.2",
		"prettier": "^3.6.2",
		"sass": "^1.99.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.6"
	},
	"lint-staged": {
		"*.{ts,tsx}": "eslint --no-warn-ignored",
		"*.{ts,tsx,css,scss,md}": "prettier --check"
	}
}
